# =============================================================================
# Google Maps API キー
# https://console.cloud.google.com/google/maps-apis
# =============================================================================

# 【スクリプト用】Geocoding API / Places API（geocode.py 等）
GOOGLE_MAPS_API_KEY=your_geocoding_api_key_here

# 【アプリ用 iOS】Maps SDK for iOS
# 制限: iOS Bundle ID → jp.oneofthem.phonebooth
GOOGLE_MAPS_IOS_API_KEY=your_ios_maps_sdk_key_here

# 【アプリ用 Android】Maps SDK for Android
# 制限: パッケージ jp.oneofthem.phonebooth + EAS Keystore の SHA-1
GOOGLE_MAPS_ANDROID_API_KEY=your_android_maps_sdk_key_here

# =============================================================================
# Supabase（Expo アプリ）EXPO_PUBLIC_ プレフィックス必須
# =============================================================================

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# =============================================================================
# Supabase（Python スクリプト用）
# =============================================================================

SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# 任意: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxx

# =============================================================================
# EAS Build（クラウドビルド用・ローカル .env とは別管理）
#   eas env:create --name GOOGLE_MAPS_IOS_API_KEY --value "..." --environment production --visibility secret
#   eas env:create --name GOOGLE_MAPS_ANDROID_API_KEY --value "..." --environment production --visibility secret
# =============================================================================
